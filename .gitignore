# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js build output (any level)
.next/

# export output
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# server build output
server/node_modules/
server/dist/
server/frontend/

# tauri build artifacts
src-tauri/resources/
src-tauri/target/
server/backups/
server/uploads/

# server-side stats files (not part of app distribution)
server/ping-server.py
server/dashboard.html

# database
*.db

# auto-generated encryption key
server/.encryption.key

# dev helpers
dev.sh
dev.md

# downloaded
playwright-*.tgz
