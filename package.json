{
  "name": "classnode",
  "version": "1.6.0",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=24"
  },
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:server": "pnpm --filter classnode-server dev",
    "dev:all": "bash dev.sh foreground",
    "build": "next build",
    "build:server": "pnpm --filter classnode-server build",
    "test": "pnpm --filter classnode-server test",
    "build:all": "pnpm build && pnpm build:server && node scripts/package-web.mjs",
    "start": "next start",
    "tauri": "tauri",
    "build:mac:arm64": "bash scripts/build-mac.sh --target aarch64-apple-darwin",
    "build:mac:intel": "bash scripts/build-mac.sh --target x86_64-apple-darwin",
    "build:windows": "node scripts/sync-version.mjs && pnpm build && pnpm build:server && node scripts/package-server.mjs --target x86_64-pc-windows-msvc && tauri build --target x86_64-pc-windows-msvc",
    "build:windows:arm64": "node scripts/sync-version.mjs && pnpm build && pnpm build:server && node scripts/package-server.mjs --target aarch64-pc-windows-msvc && tauri build --target aarch64-pc-windows-msvc",
    "sync-version": "node scripts/sync-version.mjs",
    "prepare-release": "node scripts/prepare-release.mjs",
    "prebuild": "node scripts/sync-version.mjs",
    "lint": "eslint",
    "stop": "bash dev.sh stop"
  },
  "dependencies": {
    "@isoterik/react-word-cloud": "^1.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "docx": "^9.7.0",
    "katex": "^0.17.0",
    "next": "16.2.6",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
