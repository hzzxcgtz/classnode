{
  "name": "classnode",
  "version": "1.2.0",
  "packageManager": "pnpm@11.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "pnpm --filter classnode-server dev",
    "dev:all": "pnpm dlx concurrently \"pnpm dev\" \"pnpm dev:server\"",
    "build": "next build",
    "build:server": "pnpm --filter classnode-server build",
    "build:all": "pnpm build && cp -r out server/frontend && cp -r out src-tauri/resources/server/frontend",
    "start": "next start",
    "tauri": "tauri",
    "build:mac:arm64": "node scripts/sync-version.mjs && tauri build && node scripts/rename-bundle.mjs aarch64",
    "build:mac:intel": "node scripts/sync-version.mjs && tauri build --target x86_64-apple-darwin && node scripts/rename-bundle.mjs x86_64",
    "sync-version": "node scripts/sync-version.mjs",
    "prebuild": "node scripts/sync-version.mjs",
    "lint": "eslint",
    "stop": "lsof -ti:3000,3001 | xargs kill -9"
  },
  "dependencies": {
    "@isoterik/react-word-cloud": "^1.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "docx": "^9.7.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
