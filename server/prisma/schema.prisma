generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 教师全局配置（管理密码、端口号等）
model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

// AI 智能体配置
model Agent {
  id        String   @id @default(uuid())
  name      String   // 本地展示名称
  logo      String?  // 本地 Logo 路径
  platform  String   // 平台类型: coze / dify / openai
  apiUrl    String?  // API URL (for Dify / OpenAI)
  apiKey    String   // AES 加密后的 API Key / Token
  botId     String?  // Bot ID (for Coze)
  extra     String?  // 额外配置 (JSON)
  enabled   Boolean  @default(true)
  greeting         String?   // 开场白
  greetingFetchedAt DateTime? // 开场白最后拉取时间
  lastCheckAt       DateTime? // 最后连通性检查时间
  lastCheckOk       Boolean?  // 最后检查是否成功
  lastCheckError    String?   // 最后检查错误信息
  createdAt         DateTime @default(now())
  updatedAt DateTime @updatedAt

  classroomAgents ClassroomAgent[]
  classroomGroups ClassroomGroup[]
}

// 头像库
model Avatar {
  id          Int       @id @default(autoincrement())
  svgContent  String
  category    String    @default("student") // student / class
  gender      String    @default("neutral") // boy / girl / neutral
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  source      String    @default("teacher") // teacher / student
  createdAt   DateTime  @default(now())

  students Student[]
  classes  Class[]
}

// 班级
model Class {
  id        String   @id @default(uuid())
  name      String   // 班级名称
  avatarId  Int?     // 班级图标
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  avatar           Avatar?           @relation(fields: [avatarId], references: [id])
  students         Student[]
  groups           ClassGroup[]
  classroomClasses ClassroomClass[]
}

// 班级分组（持久化，可在创建课堂时复用）
model ClassGroup {
  id         String   @id @default(uuid())
  classId    String
  name       String   // 组名
  studentIds String   @default("[]") // 学生 ID 数组 JSON ["uuid1","uuid2"]
  createdAt  DateTime @default(now())

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, name])
}

// 学生
model Student {
  id        String   @id @default(uuid())
  classId   String
  name      String   // 学生姓名
  studentNo String?  // 学号
  gender    String?  // boy / girl（用于头像匹配、自动分配）
  tag       String?  // 分组标签 (如 A组, B组)
  avatarId           Int?     // 学生头像
  avatarChangeTokens Int      @default(0) // 教师奖励的可换头像次数
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class     Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  avatar    Avatar?         @relation(fields: [avatarId], references: [id])
  classroomStudents ClassroomStudent[]
}

// 课堂
model Classroom {
  id        String   @id @default(uuid())
  code      String?  @unique // 4位互动码（结束课堂时置空以回收）
  title     String?  // 课堂标题
  mode      String   @default("standard") // standard / advanced
  status    String   @default("active") // active / ended
  createdAt DateTime @default(now())
  endedAt   DateTime?

  classes          ClassroomClass[]
  groups           ClassroomGroup[]
  students         ClassroomStudent[]
  classroomAgents  ClassroomAgent[]
  interactions     Interaction[]
  shieldWarnings   ShieldWarning[]
  notifications    TeacherNotification[]
}

// 课堂关联的班级（标准模式）
model ClassroomClass {
  classroomId String
  classId     String

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([classroomId, classId])
}

// 课堂分组（高级模式）
model ClassroomGroup {
  id          String @id @default(uuid())
  classroomId String
  name        String // 组名
  agentId    String // 该组绑定的智能体
  code        String?  @unique // 该组的互动码（结束课堂时置空回收）

  classroom Classroom       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  agent     Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  students  ClassroomStudent[]
}

// 课堂中的智能体关联
model ClassroomAgent {
  id          String @id @default(uuid())
  classroomId String
  agentId     String

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, agentId])
}

// 课堂中的学生
model ClassroomStudent {
  id          String   @id @default(uuid())
  classroomId String
  studentId   String
  groupId     String?  // 所属组（高级模式）
  joinTime    DateTime @default(now())
  status      String   @default("offline") // online / offline
  totalRounds Int      @default(0)
  warningCount Int    @default(0)
  blacklisted  Boolean @default(false)

  classroom Classroom      @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group     ClassroomGroup? @relation(fields: [groupId], references: [id])
  messages  Message[]

  @@unique([classroomId, studentId])
  @@index([classroomId, status])
  @@index([studentId])
}

// 互动消息
model Message {
  id               String   @id @default(uuid())
  classroomId      String
  studentId        String
  content          String   // 消息原文
  role             String   // user / assistant
  displayName      String?  // 脱敏后的显示名
  roundIndex       Int?     // 第几轮
  agentId          String?  // 回复的智能体
  fileUrls         String?  // 附件 URL 列表（JSON 数组）
  fileNames        String?  // 附件名称列表（JSON 数组）
  createdAt        DateTime @default(now())

  classroomStudent ClassroomStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([classroomId])
  @@index([studentId])
  @@index([classroomId, createdAt])
}

// 屏蔽词
model ShieldWord {
  id        String   @id @default(uuid())
  word      String   @unique
  builtin   Boolean  @default(false)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

// 屏蔽系统配置
model ShieldConfig {
  id             String @id @default(uuid())
  autoBlackCount Int    @default(0) // 0=不自动黑屏，N=警告N次后自动黑屏
  rateLimit      Int    @default(6) // 每分钟最多提问次数，0=不限制
}

// 屏蔽警告记录
model ShieldWarning {
  id          String   @id @default(uuid())
  classroomId String
  studentId   String   // ClassroomStudent.id
  word        String   // 触发的屏蔽词
  content     String?  // 触发时的消息内容片段
  createdAt   DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
}

// 教师通知（全班广播或发给指定学生，持久化到 DB 支持导出）
model TeacherNotification {
  id          String   @id @default(uuid())
  classroomId String
  studentId   String?  // null = 全班广播 或 定向到组，非空 = 发送给指定学生（Student.id）
  groupId     String?  // 定向到组（高级/分组模式），studentId=null 时 groupId 有值
  content     String
  createdAt   DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([classroomId, createdAt])
  @@index([classroomId, groupId])
}

// 互动记录汇总
model Interaction {
  id          String   @id @default(uuid())
  classroomId String
  studentId   String
  totalRounds Int      @default(0)
  firstMsgLen Int?     // 首问字数
  avgTime     Int?     // 平均响应时间(秒)
  createdAt   DateTime @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@index([classroomId])
}
