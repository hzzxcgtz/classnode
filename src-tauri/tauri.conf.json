{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ClassNode",
  "version": "1.3.2",
  "identifier": "com.classnode.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "rm -rf src-tauri/resources/server/frontend && cp -r out src-tauri/resources/server/frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources": "."
    }
  }
}
